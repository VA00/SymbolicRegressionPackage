Notebook[{

Cell[CellGroupData[{
Cell["EML Verification", "Title",ExpressionUUID->"8b1f0d21-5115-4fc3-8f3c-1722f191ac6d"],

Cell["\<\
Minimal verification notebook for VerifyBaseSet using the EML Sheffer \
operator and the public package entrypoint.\
\>", "Text",ExpressionUUID->"76679426-65ff-423c-90d0-9c2abb96d0b1"],

Cell["\<\
Run the import first, then evaluate the verification call to reproduce the \
package check. This is re-creation of the original run, which led to \
discovery of  EML operator candidate. \
\>", "Text",
 CellChangeTimes->{{3.983246151593916*^9, 
  3.9832462095182056`*^9}},ExpressionUUID->"c4b391e3-c0b7-4e10-b367-\
324691adb2e7"],

Cell[CellGroupData[{

Cell["Package Import And Verification", "Section",ExpressionUUID->"2baea2a8-e4e4-4828-8555-edde7547688f"],

Cell["\<\
Loads the package from the public repository, defines the local EML operator, \
and launches the base-set verification routine.\
\>", "Text",ExpressionUUID->"a12eab0a-b64a-48dd-9ecc-6b0a6ae69375"],

Cell[BoxData[
 RowBox[{"Import", 
  "[", "\"\<https://raw.githubusercontent.com/VA00/SymbolicRegressionPackage/\
refs/heads/master/SymbolicRegression.m\>\"", "]"}]], "Input",
 CellLabel->"In[1]:=",ExpressionUUID->"c4a262cb-17d4-40fc-8571-2131f134f1cb"],

Cell[BoxData[
 RowBox[{
  RowBox[{"EML", "[", 
   RowBox[{"x_", ",", "y_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{"Exp", "[", "x", "]"}], "-", 
   RowBox[{"Log", "[", "y", "]"}]}]}]], "Input",
 CellLabel->"In[2]:=",ExpressionUUID->"01e3f325-4b59-4f45-a595-9c970a0f079f"],

Cell[BoxData[
 RowBox[{"VerifyBaseSet", "[", 
  RowBox[{
   RowBox[{"{", "1", "}"}], ",", 
   RowBox[{"{", "}"}], ",", 
   RowBox[{"{", "EML", "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.981211010446392*^9, 3.9812110153514824`*^9}, {
   3.9812620838450375`*^9, 3.9812620847448044`*^9}, 
   3.9812666393087387`*^9},ExpressionUUID->"75f6380e-ff16-4780-aa0e-\
7a86f78467c2"]
}, Open  ]]
}, Open  ]]
},
