                   RowBox[{"(", "1", ")"}]}], ")"}], ")"}]}], ")"}], ")"}]}], 
            ")"}], ")"}], "~", "EmL", "~", 
          RowBox[{"(", "1", ")"}]}], ")"}], ")"}]}], ")"}], ")"}], "~", "EmL",
     "~", 
    RowBox[{"(", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"(", "1", ")"}], "~", "EmL", "~", 
          RowBox[{"(", "1", ")"}]}], ")"}], ")"}], "~", "EmL", "~", 
       RowBox[{"(", "1", ")"}]}], ")"}], ")"}]}], ")"}]}]], "Input",
 CellChangeTimes->{{3.9654594091556644`*^9, 3.9654594091556644`*^9}, {
  3.9654605609135113`*^9, 3.9654605615658627`*^9}},
 CellLabel->"In[25]:=",ExpressionUUID->"0463d384-f45f-7944-be61-53d70149b13e"],

Cell[BoxData[
 RowBox[{"zero", "=", 
  RowBox[{"(", 
   RowBox[{
    RowBox[{"(", "1", ")"}], "~", "EmL", "~", 
    RowBox[{"(", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"(", "1", ")"}], "~", "EmL", "~", 
