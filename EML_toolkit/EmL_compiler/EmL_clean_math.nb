 RowBox[{"Log", "[", 
  RowBox[{"-", "1"}], "]"}]], "Input",
 CellChangeTimes->{{3.9826437318576374`*^9, 3.982643733550991*^9}},
 CellLabel->"In[29]:=",ExpressionUUID->"d46129dd-be52-7145-bcb4-70bc1cbcc556"],

Cell[BoxData[
 RowBox[{
