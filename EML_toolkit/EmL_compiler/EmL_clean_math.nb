Notebook[{

Cell[CellGroupData[{
Cell["EML Clean Math Constructions", "Title",ExpressionUUID->"6dc165b4-9901-4a81-99fe-3661d13d5642"],

Cell["\<\
This notebook explores EML identities that avoid problematic infinities, then \
packages them into cleaner rules for logarithms, subtraction, negation, and \
small rational constants.\
\>", "Text",ExpressionUUID->"51d9afd5-c613-42c6-b942-83e0fa9075be"],

Cell["\<\
Evaluate interactively from top to bottom; the early exploratory outputs \
motivate the later constructive formulas.\
\>", "Text",ExpressionUUID->"d15908ab-c2b3-47f1-9ba8-c6e2ff1bf052"],

Cell[CellGroupData[{

Cell["Handling Log[0]", "Section",ExpressionUUID->"ec1deea9-eab4-4304-825d-010dab064b27"],

Cell["Establishes the working convention for Log[0].", "Text",
 CellChangeTimes->{{3.9832454633750973`*^9, 
  3.983245481606556*^9}},ExpressionUUID->"69a49bc7-52cd-4e61-8ed8-\
f3f41d47a18e"],

Cell[BoxData[
 RowBox[{"Unprotect", "[", "Log", "]"}]], "Input",
 CellChangeTimes->{{3.98232790058535*^9, 3.9823279052407875`*^9}},
 CellLabel->"In[12]:=",ExpressionUUID->"6d84b72e-86fd-814c-8ac2-200e0b67398c"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Log", "[", "0", "]"}], "=", "Undefined", " ", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"This", " ", "is", " ", "to", " ", "ensure", " ", 
     RowBox[{"Log", "[", "0", "]"}]}], "=", 
    RowBox[{
     RowBox[{"-", "Infinity"}], " ", "is", " ", "not", " ", "being", " ", 
     "used", " ", "for", " ", "evaluation"}]}], " ", "*)"}]}]], "Input",
 CellChangeTimes->{{3.9823279074103203`*^9, 3.9823279125628204`*^9}, {
  3.9823289180210705`*^9, 3.9823289378735275`*^9}},
 CellLabel->"In[13]:=",ExpressionUUID->"bb9d665f-8642-fd42-b742-b45d3d0725d0"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Evaluation Rules", "Section",ExpressionUUID->"c487be14-329d-41e7-b7d1-982cc966ef3f"],

Cell["\<\
Introduces symbolic, numeric, and real-valued EML evaluation rules and checks \
how they behave on representative inputs without relying on infinities.\
\>", "Text",ExpressionUUID->"679d3f72-d5e7-4d17-8965-2eee8fc25ef2"],

Cell[BoxData[
 RowBox[{"emlRule", "=", 
  RowBox[{"EmL", "->", 
   RowBox[{"Function", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"x", ",", "y"}], "}"}], ",", 
     RowBox[{
      RowBox[{"Exp", "[", "x", "]"}], "-", 
      RowBox[{"Log", "[", "y", "]"}]}]}], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.9823289844514523`*^9, 3.982329004872883*^9}},
 CellLabel->"In[1]:=",ExpressionUUID->"32f2740f-d8fd-0d4f-aec9-75ef47efd56d"],

Cell[BoxData[
 RowBox[{"emlRuleN", "=", 
  RowBox[{"EmL", "->", 
   RowBox[{"Function", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"x", ",", "y"}], "}"}], ",", 
     RowBox[{
      RowBox[{"Exp", "[", 
       RowBox[{"N", "@", "x"}], "]"}], "-", 
      RowBox[{"Log", "[", 
       RowBox[{"N", "@", "y"}], "]"}]}]}], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.9823290069142876`*^9, 3.9823290216957703`*^9}},
 CellLabel->"In[2]:=",ExpressionUUID->"de7b541d-4ad5-854d-96d8-173b020a6e8e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"realEML", "[", 
   RowBox[{
    RowBox[{"x_", "?", "RealValuedNumericQ"}], ",", 
    RowBox[{"y_", "?", "RealValuedNumericQ"}]}], "]"}], ":=", 
  RowBox[{
   RowBox[{"Exp", "[", "x", "]"}], "-", 
   RowBox[{"Log", "[", "y", "]"}], " ", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"Pure", " ", "real", " ", "EML"}], " ", "-", " ", 
     RowBox[{
     "not", " ", "likely", " ", "to", " ", "work", " ", "at", " ", "all"}]}], 
    " ", "*)"}]}]}]], "Input",
 CellChangeTimes->{{3.9823295668726616`*^9, 3.9823296498038464`*^9}, {
  3.982329713771204*^9, 3.982329716531122*^9}, {3.98233005125264*^9, 
  3.9823300567873*^9}, {3.982643635687996*^9, 3.982643646907955*^9}},
 CellLabel->"In[3]:=",ExpressionUUID->"84a242e0-129f-ae4c-bd8a-37225130bef5"],

Cell[BoxData[
 RowBox[{"realEML", "[", 
  RowBox[{
   RowBox[{"-", "1"}], ",", "I"}], "]"}]], "Input",
 CellChangeTimes->{{3.9823296259155483`*^9, 3.982329629483774*^9}, {
  3.9823297223889084`*^9, 3.982329732305088*^9}},
 CellLabel->"In[4]:=",ExpressionUUID->"8f6ab946-16d4-8648-829c-a0b0fa335991"],

Cell[BoxData[
 RowBox[{"realEML", "[", 
  RowBox[{"E", ",", "Pi"}], "]"}]], "Input",
 CellChangeTimes->{{3.9823300608467045`*^9, 3.982330063566328*^9}},
 CellLabel->"In[5]:=",ExpressionUUID->"073f2df6-ee57-054c-ba74-1c4e1c668b7e"],

Cell[BoxData[
 RowBox[{"emlRuleReal", "=", 
  RowBox[{"EmL", "->", "realEML"}]}]], "Input",
 CellChangeTimes->{{3.9823295381015415`*^9, 3.9823295548174934`*^9}, {
  3.9823297396766205`*^9, 3.9823297496611385`*^9}, {3.982329851100233*^9, 
  3.982329931668644*^9}, {3.982329978873972*^9, 3.9823299799169273`*^9}},
 CellLabel->"In[6]:=",ExpressionUUID->"67ba0054-84f6-be43-9584-0d76af333d1d"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Clean exp/log Building Blocks", "Section",ExpressionUUID->"c0f095a2-cc01-49eb-8f89-7b05557580c0"],

Cell["\<\
Builds compact EML versions of exp and log and tests them against standard \
evaluations, including the branch behavior at negative arguments.\
\>", "Text",ExpressionUUID->"48e44928-6e9a-4c59-911f-236c60e90985"],

Cell[BoxData[
 RowBox[{"exp", "=", 
  RowBox[{
   RowBox[{"EmL", "[", 
    RowBox[{"#", ",", "1"}], "]"}], "&"}], " ", 
  RowBox[{"(*", " ", 
   RowBox[{"Clean", " ", "exp"}], " ", "*)"}]}]], "Input",
 CellChangeTimes->{{3.96548594383638*^9, 3.9654859595900326`*^9}, {
  3.9823289492210197`*^9, 3.9823289535783653`*^9}},
 CellLabel->"In[7]:=",ExpressionUUID->"bb3b7ad3-ff6d-ee4e-a523-182ec1254299"],

Cell[BoxData[
 RowBox[{"ln", "=", 
  RowBox[{
   RowBox[{"EmL", "[", 
    RowBox[{"1", ",", 
     RowBox[{"EmL", "[", 
      RowBox[{
       RowBox[{"EmL", "[", 
        RowBox[{"1", ",", "#"}], "]"}], ",", "1"}], "]"}]}], "]"}], "&"}], 
  " ", 
  RowBox[{"(*", " ", 
   RowBox[{"Clean", " ", "Log"}], " ", "*)"}]}]], "Input",
 CellChangeTimes->{{3.965524484154331*^9, 3.9655244927414856`*^9}, {
  3.982328962473957*^9, 3.9823289677684383`*^9}},
 CellLabel->"In[8]:=",ExpressionUUID->"17668907-e9d6-0e4b-8027-33b657576e21"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"ln", "[", "1", "]"}], "/.", "emlRule"}], "//", 
  "Simplify"}]], "Input",
 CellChangeTimes->{{3.982329027142273*^9, 3.982329040911188*^9}, {
  3.982643688992401*^9, 3.9826436895162773`*^9}},
 CellLabel->"In[9]:=",ExpressionUUID->"0a64efbe-83e6-6043-999e-fb1feb2715ab"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"ln", "[", 
    RowBox[{"-", "1"}], "]"}], "/.", "emlRule"}], "//", "Simplify"}]], "Input",
