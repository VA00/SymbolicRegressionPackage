   RowBox[{"0", ",", "0"}], "]"}], "/.", "emlRule"}]], "Input",
 CellChangeTimes->{{3.9826437046018295`*^9, 3.982643715551756*^9}},
 CellLabel->"In[14]:=",ExpressionUUID->"09a1cd85-cf63-1c41-982f-fc5ff048db50"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"(", 
    RowBox[{
     RowBox[{"ln", "[", "Pi", "]"}], "/.", "emlRuleN"}], ")"}], "/", 
   RowBox[{"Log", "[", "Pi", "]"}]}], "-", "1"}]], "Input",
 CellChangeTimes->{{3.9823290498517246`*^9, 3.982329059841156*^9}},
 CellLabel->"In[15]:=",ExpressionUUID->"53a4aa47-73b8-e245-9957-af0604943aba"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Subtraction And Negation", "Section",ExpressionUUID->"956748f0-ef15-4224-a5f6-40a937c2779e"],

Cell["\<\
Derives subtraction and a usable negation construction, then probes the \
resulting formulas on positive, negative, and singular test cases.\
\>", "Text",ExpressionUUID->"b9a544bf-5da3-47fb-bd61-b05edcaa8a00"],

Cell[BoxData[
 RowBox[{"subtract", " ", "=", 
  RowBox[{
   RowBox[{"EmL", "[", 
    RowBox[{
     RowBox[{"EmL", "[", 
      RowBox[{"1", ",", 
       RowBox[{"EmL", "[", 
        RowBox[{
         RowBox[{"EmL", "[", 
          RowBox[{"1", ",", "#1"}], "]"}], ",", "1"}], "]"}]}], "]"}], ",", 
     RowBox[{"EmL", "[", 
      RowBox[{"#2", ",", "1"}], "]"}]}], "]"}], "&"}]}]], "Input",
 CellChangeTimes->{{3.965967207516468*^9, 3.9659672158193893`*^9}, {
  3.9659673101499844`*^9, 3.9659673181823654`*^9}},
 CellLabel->"In[16]:=",ExpressionUUID->"a97d1e41-e9d7-cf41-b473-d83ac1dd8cda"],

