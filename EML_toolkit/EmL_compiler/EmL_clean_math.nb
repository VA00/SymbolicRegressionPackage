  3.982329071414633*^9, 3.982329073157181*^9}},
 CellLabel->"In[17]:=",ExpressionUUID->"eb1c80da-f82f-a149-9043-50f912a1cc38"],

Cell[BoxData[
 RowBox[{
  RowBox[{"subtract", "[", 
   RowBox[{"0", ",", "x"}], "]"}], "/.", "emlRule", " ", 
  RowBox[{"(*", " ", 
   RowBox[{"Still", " ", "no", " ", "proper", " ", 
    RowBox[{"negation", "!"}]}], " ", "*)"}]}]], "Input",
 CellChangeTimes->{{3.9823290810998898`*^9, 3.9823290929721603`*^9}, {
  3.9823291475944366`*^9, 3.982329159894825*^9}},
 CellLabel->"In[18]:=",ExpressionUUID->"df7db547-5db1-1d4a-b1e6-7359d91319a9"],

Cell[BoxData[
 RowBox[{"minus", "=", 
  RowBox[{"(", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"ln", "[", 
         RowBox[{"ln", "[", "x", "]"}], "]"}], ")"}], "~", "EmL", "~", 
       RowBox[{"(", 
        RowBox[{"(", 
         RowBox[{"-", "1"}], ")"}], ")"}]}], ")"}], ")"}], "~", "EmL", "~", 
    RowBox[{"(", "1", ")"}]}], ")"}], " ", 
