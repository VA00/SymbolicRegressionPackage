Cell[CellGroupData[{

Cell["Encoded Constants", "Section",ExpressionUUID->"8bd8de97-cba5-4a84-a1c2-c79c01a9137e"],

Cell["\<\
Constructs clean EML encodings for -1, 0, 2, and 1/2 and verifies them under \
symbolic, numeric, and purely real evaluation rules.\
\>", "Text",ExpressionUUID->"d9f9fe64-92b4-472c-a13c-545e62a3dc78"],

Cell[BoxData[
 RowBox[{"neg", "=", 
  RowBox[{"(", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"(", "1", ")"}], "~", "EmL", "~", 
       RowBox[{"(", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"(", "1", ")"}], "~", "EmL", "~", 
