Cell[BoxData[
 RowBox[{"Table", "[", 
  RowBox[{
   RowBox[{"FullSimplify", "[", 
    RowBox[{
     RowBox[{"funcsZeroTest", "[", 
      RowBox[{"[", "ii", "]"}], "]"}], ",", 
     RowBox[{"funcsRealDomain", "[", 
      RowBox[{"[", "ii", "]"}], "]"}]}], "]"}], ",", 
