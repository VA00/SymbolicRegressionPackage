Cell[BoxData[
 RowBox[{"constRAW", "=", 
  RowBox[{
  "Import", "[", "\"\<eml_tests_out/const_orig.wl\>\"", "]"}]}]], "Input",
 CellChangeTimes->{{3.966497973671665*^9, 3.966497982334593*^9}, 
   3.966502189485428*^9, {3.966502280440407*^9, 3.9665022851432285`*^9}, {
   3.9665044819760265`*^9, 3.9665044844528866`*^9}, {3.9671763826471157`*^9, 
   3.967176384289158*^9}},
 CellLabel->"In[12]:=",ExpressionUUID->"687c9a19-48a3-6648-8198-40355664647a"],

Cell[BoxData[
 RowBox[{"const", "=", 
  RowBox[{"constEML", "/.", "emlRuleStdBranch"}]}]], "Input",
 CellLabel->"In[13]:=",ExpressionUUID->"688867da-5baa-414c-b9b4-ef34e491c3a7"],

Cell[BoxData[
 RowBox[{"constSimplified", "=", 
  RowBox[{"FullSimplify", "[", "const", "]"}]}]], "Input",
 CellChangeTimes->{{3.9671763645415573`*^9, 3.967176367083811*^9}, {
  3.981111607501919*^9, 3.981111637988859*^9}},
 CellLabel->"In[14]:=",ExpressionUUID->"58ab8441-d1c0-4e43-a561-7bca44b83e19"],

Cell[BoxData[
 RowBox[{
  RowBox[{"constRAW", "-", "constSimplified"}], "//", "Simplify", " ", 
  RowBox[{"(*", " ", 
   RowBox[{"Expected", " ", "all", " ", "zeros"}], " ", "*)"}]}]], "Input",
 CellChangeTimes->{{3.981111643714222*^9, 3.981111656626772*^9}, {
  3.9811116908810616`*^9, 3.9811117102009087`*^9}},
 CellLabel->"In[15]:=",ExpressionUUID->"9668da03-8d86-444c-a2ff-84c645f898a2"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Unary Functions", \
"Section",ExpressionUUID->"000d7f1d-1877-4e4b-a3aa-cd98e040f28a"],

Cell["\<\
Imports compiler-generated unary functions, computes their real domains, \
simplifies them, and stress-tests the residual differences on representative \
constant values.\
\>", "Text",ExpressionUUID->"704c13b3-4db4-48bf-9449-8f5f53948fe3"],

Cell[BoxData[
 RowBox[{
  RowBox[{"funcsEML", "=", 
   RowBox[{"Import", "[", "\"\<eml_tests_out/funcs_eml.wl\>\"", "]"}]}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.9664962543311768`*^9, 3.9664962692552567`*^9}, {
  3.966498136000065*^9, 3.9664981426589546`*^9}},
 CellLabel->"In[16]:=",ExpressionUUID->"99921c2d-f7a3-e64d-8026-fbdbcff94433"],

Cell[BoxData[
 RowBox[{"funcsRAW", "=", 
  RowBox[{
