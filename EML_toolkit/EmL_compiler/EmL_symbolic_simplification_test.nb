     RowBox[{"ii", ",", "1", ",", 
      RowBox[{"Length", "[", "funcs", "]"}]}], "}"}]}], "]"}], " ", 
  RowBox[{"(*", " ", 
   RowBox[{"Expected", " ", "all", " ", "zeros"}], " ", "*)"}]}]], "Input",
 CellChangeTimes->{{3.9811125522840233`*^9, 3.9811126344330635`*^9}, {
  3.981113296318838*^9, 3.981113302184309*^9}, {3.9811136407592106`*^9, 
  3.98111365522007*^9}},
 CellLabel->"In[24]:=",ExpressionUUID->"47f1f11e-1684-df47-9c0a-7553aa87087e"],

Cell[BoxData[
 RowBox[{"(*", " ", 
  RowBox[{
   RowBox[{"Using", " ", "PowerExpand"}], ",", " ", 
   RowBox[{
   "and", " ", "excluding", " ", "domain", " ", "endpoints", " ", "for", " ", 
    "ArcCos", " ", "simplified", " ", "all", " ", "but", " ", "one"}]}], " ", 
  "*)"}]], "Input",
 CellChangeTimes->{{3.981115229789133*^9, 3.9811152661565723`*^9}},
 CellLabel->"In[25]:=",ExpressionUUID->"ab7e770b-72c8-b742-b6e7-e2aa0f4e83b0"],

Cell[BoxData[
 RowBox[{"Table", "[", 
  RowBox[{
   RowBox[{"FullSimplify", "[", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"funcsZeroTest", "[", 
        RowBox[{"[", "ii", "]"}], "]"}], "//", "PowerExpand"}], "//", 
      "TrigToExp"}], ",", 
     RowBox[{
      RowBox[{"funcsRealDomain", "[", 
       RowBox[{"[", "ii", "]"}], "]"}], "&&", 
      RowBox[{"x", "!=", "1"}], "&&", 
      RowBox[{"x", "!=", 
       RowBox[{"-", "1"}]}]}]}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"ii", ",", "1", ",", 
     RowBox[{"Length", "[", "funcs", "]"}]}], "}"}]}], "]"}]], "Input",
