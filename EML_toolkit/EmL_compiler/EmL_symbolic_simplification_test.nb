Cell[BoxData[
 RowBox[{
  RowBox[{"funcsEML", "[", 
   RowBox[{"[", "3", "]"}], "]"}], "/.", "emlRuleStdBranch"}]], "Input",
 CellChangeTimes->{{3.981111837444805*^9, 3.9811118642885704`*^9}, {
  3.9811119829347897`*^9, 3.981111983469139*^9}},
 CellLabel->"In[18]:=",ExpressionUUID->"b59cdcaa-d13b-c540-a309-ff663796f41c"],

Cell[BoxData[
 RowBox[{"funcs", " ", "=", " ", 
  RowBox[{"funcsEML", "/.", "emlRuleStdBranch"}]}]], "Input",
 CellChangeTimes->{{3.981111764775076*^9, 3.981111787981043*^9}, {
  3.981111996067095*^9, 3.9811119966236286`*^9}},
 CellLabel->"In[19]:=",ExpressionUUID->"112c7a96-e81a-7a48-baff-534a070c3aa5"],

Cell[BoxData[
 RowBox[{
  RowBox[{"funcsRealDomain", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"FunctionDomain", "[", 
        RowBox[{"#", ",", " ", "x"}], "]"}], " ", "&"}], ")"}], "/@", 
     "funcsRAW"}], " ", "/.", " ", 
    RowBox[{"True", "->", 
     RowBox[{"(", 
      RowBox[{"x", "\[Element]", "Reals"}], ")"}]}]}]}], ";"}]], "Input",
 CellChangeTimes->{{3.967182055170641*^9, 3.9671820615148983`*^9}, {
  3.981112706367588*^9, 3.981112727315716*^9}},
 CellLabel->"In[20]:=",ExpressionUUID->"c4db5e5a-989c-1b42-98b1-bce74c2ae756"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"{", 
    RowBox[{"funcsRAW", ",", "funcsRealDomain"}], "}"}], "//", "Transpose"}], 
  "//", "TableForm", " ", 
  RowBox[{"(*", " ", 
   RowBox[{
   "EML", " ", "form", " ", "is", " ", "expected", " ", "to", " ", "work", " ",
     "at", " ", "least", " ", "on", " ", "real", " ", "axis"}], " ", 
   "*)"}]}]], "Input",
 CellChangeTimes->{{3.9671818400946846`*^9, 3.967181848331356*^9}, {
  3.9671819106340103`*^9, 3.967181918867855*^9}, {3.9671820527399445`*^9, 
  3.9671820662578716`*^9}, {3.98111920346434*^9, 3.981119237868294*^9}},
 CellLabel->"In[21]:=",ExpressionUUID->"44ad905d-7d74-4d4e-91ad-2b778d0ea86c"],

Cell[BoxData[
 RowBox[{"funcsSimplified", " ", "=", 
  RowBox[{"(*", "Parallel", "*)"}], 
  RowBox[{"Table", "[", " ", 
   RowBox[{
    RowBox[{"FullSimplify", "[", 
     RowBox[{
      RowBox[{"funcs", "[", 
       RowBox[{"[", "ii", "]"}], "]"}], ",", " ", 
      RowBox[{"funcsRealDomain", "[", 
       RowBox[{"[", "ii", "]"}], "]"}]}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"ii", ",", "1", ",", 
      RowBox[{"Length", "[", "funcs", "]"}]}], "}"}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.9811120070505753`*^9, 3.9811120165063515`*^9}, {
   3.9811120872324314`*^9, 3.981112092723839*^9}, {3.9811121799066124`*^9, 
   3.981112183205948*^9}, {3.981112421593279*^9, 3.98111244992223*^9}, {
   3.9811127434784164`*^9, 3.9811127448805065`*^9}, {3.981119278558666*^9, 
   3.9811192828925705`*^9}, 3.981119317166218*^9},
 CellLabel->"In[22]:=",ExpressionUUID->"02fe1737-aed5-7047-af31-12bce9c8ccaf"],

Cell[BoxData[
 RowBox[{"(*", " ", 
  RowBox[{
  "Some", " ", "trigonometric", " ", "functions", " ", "remain", " ", 
   "unsimplified", " ", "by", " ", "Mathematica"}], " ", "*)"}]], "Input",
 CellChangeTimes->{{3.9811151656324425`*^9, 3.9811151844111595`*^9}},
 CellLabel->"In[23]:=",ExpressionUUID->"862267e1-6629-0a4d-96c9-59a28af76131"],

Cell[BoxData[
 RowBox[{"funcsZeroTest", " ", "=", " ", 
  RowBox[{"Table", "[", 
   RowBox[{
    RowBox[{"FullSimplify", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"funcsRAW", "[", 
        RowBox[{"[", "ii", "]"}], "]"}], "-", 
       RowBox[{"funcsSimplified", "[", 
        RowBox[{"[", "ii", "]"}], "]"}]}], ",", 
      RowBox[{"funcsRealDomain", "[", 
       RowBox[{"[", "ii", "]"}], "]"}]}], "]"}], ",", 
