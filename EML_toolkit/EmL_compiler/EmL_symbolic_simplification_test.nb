Notebook[{

Cell[CellGroupData[{
Cell["EML Symbolic Simplification Tests", \
"Title",ExpressionUUID->"b3a274e5-c30d-4a36-9228-2d7a8fd066ea"],

Cell["\<\
This notebook compares compiler-generated EML expressions against target \
constants, unary functions, and binary operations under the intended branch \
conventions.\
\>", "Text",ExpressionUUID->"8a3a0081-fae8-46b6-ada9-899f00ce27af"],

Cell["\<\
Evaluate top to bottom; later sections rely on imported compiler outputs from \
eml_tests_out.\
\>", "Text",ExpressionUUID->"5892fbbb-4694-4fca-aebb-ec2f349de100"],

Cell[CellGroupData[{

Cell["Setup", \
"Section",ExpressionUUID->"7c9826a0-70f2-4058-92b2-f94bbfae3c27"],

Cell["\<\
Initializes the working directory, defines helper aliases missing in \
Mathematica, and sets the active EML evaluation rules. Optional alternative \
rules and experimental variants from the raw notes are summarized here rather \
than left as standalone commented input cells.\
\>", "Text",ExpressionUUID->"ef33896a-14f6-407e-bb0e-265a3ad1fbae"],

Cell[BoxData[
 RowBox[{
  RowBox[{"SetDirectory", "[", 
   RowBox[{"NotebookDirectory", "[", "]"}], "]"}], ";"}]], "Input",
 CellLabel->"In[1]:=",ExpressionUUID->"36e3fd7b-7cfa-7249-82a4-79227d76b704"],

Cell[BoxData[
 RowBox[{"Clear", "[", "EML", "]"}]], "Input",
 CellChangeTimes->{{3.9664987918910275`*^9, 3.9664987955796623`*^9}},
 CellLabel->"In[2]:=",ExpressionUUID->"43123149-9d98-b34f-a2a7-e76da4d917bb"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Define", " ", "function", " ", "names", " ", "missing", " ", "in", " ", 
    "Mathematica"}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"Half", "[", "x_", "]"}], ":=", 
     RowBox[{"x", "/", "2"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"Avg", "[", 
      RowBox[{"x_", ",", "y_"}], "]"}], ":=", 
     RowBox[{"Mean", "[", 
      RowBox[{"{", 
       RowBox[{"x", ",", "y"}], "}"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"Sqr", "[", "x_", "]"}], ":=", 
     RowBox[{"x", "*", "x"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"Inv", "[", "x", "]"}], ":=", 
     RowBox[{"1", "/", "x"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"Hypot", "[", 
      RowBox[{"x_", ",", "y_"}], "]"}], ":=", 
     RowBox[{"Sqrt", "[", 
      RowBox[{
       RowBox[{"x", "^", "2"}], "+", 
       RowBox[{"y", "^", "2"}]}], "]"}]}], ";"}]}]}]], "Input",
 CellChangeTimes->{{3.966498341882803*^9, 3.966498349588749*^9}, {
   3.967182217670353*^9, 3.9671822432022076`*^9}, 3.967182283552204*^9, {
   3.981118947699806*^9, 3.981118967426586*^9}},
 CellLabel->"In[3]:=",ExpressionUUID->"610672ca-8879-0a4e-b102-2c71199fca6a"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"emlRule", "=", 
    RowBox[{"EML", "->", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        RowBox[{"Exp", "[", "#1", "]"}], "-", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"Im", "[", "#2", "]"}], "==", "0"}], "&&", 
           RowBox[{
            RowBox[{"Re", "[", "#2", "]"}], "<", "0"}]}], ",", 
          RowBox[{
           RowBox[{"Log", "[", "#2", "]"}], "-", 
           RowBox[{"2", "Pi", " ", "I"}]}], ",", 
          RowBox[{"Log", "[", "#2", "]"}]}], "]"}]}], "&"}], ")"}]}]}], " ", 
   ";"}], 
  RowBox[{"(*", " ", 
   RowBox[{
   "EML", " ", "branch", " ", "restorind", " ", "standard", " ", "principal", 
    " ", "branch", " ", "of", " ", 
    RowBox[{
     RowBox[{"Log", "[", "z", "]"}], ".", " ", "Note"}], " ", "it", " ", "is",
     " ", "required", " ", "only", " ", "to", " ", "get", " ", "proper", " ", 
    "imaginary", " ", 
    RowBox[{"unit", "."}]}], " ", "*)"}]}]], "Input",
 CellChangeTimes->{{3.966496202467287*^9, 3.9664962254099674`*^9}, {
  3.967163233216812*^9, 3.9671632967062473`*^9}, {3.9671634819012775`*^9, 
  3.967163484780962*^9}, {3.9811190012085056`*^9, 3.9811190647375755`*^9}},
 CellLabel->"In[8]:=",ExpressionUUID->"ffaa2574-357c-ec4c-bfc7-a1becb18dae0"],

Cell[BoxData[
 RowBox[{
  RowBox[{"emlRuleStdBranch", "=", 
   RowBox[{"EML", "->", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"Exp", "[", "#1", "]"}], "-", 
       RowBox[{"Log", "[", "#2", "]"}]}], "&"}], ")"}]}]}], ";"}]], "Input",
 CellChangeTimes->{{3.967187905389204*^9, 3.9671879152281494`*^9}, 
   3.9811190676780033`*^9},
 CellLabel->"In[9]:=",ExpressionUUID->"4f388408-43a7-b443-8b03-d12663a9dd16"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Constants", \
"Section",ExpressionUUID->"e73cd94f-b6d8-4c4e-bf13-0cfd022b7c71"],

Cell["Run the compiler to emit test cases.", \
"Text",ExpressionUUID->"6f27cb12-d0dc-ad45-9a13-6a6e0c02db17"],

Cell["\<\
cd /d \\\"\" <> NotebookDirectory[] <> \"\\\" && python3 eml_compiler_v4.py \
--emit-test\
\>", "ExternalLanguage",
 TaggingRules-><|
  "ExternalEvaluateData" -> <|
    "System" -> "Shell", "SessionID" -> "default-shell-session", "Evaluator" -> 
     Automatic|>|>,
 CellEvaluationLanguage->"Shell",
 CellLabel->"In[10]:=",ExpressionUUID->"5f73fd9e-b681-c245-bc46-76f75d733774"],

Cell["\<\
Imports the compiler output for constants, rewrites it onto the standard \
branch, and checks that the simplified difference vanishes.\
\>", "Text",ExpressionUUID->"bdc704ac-d8bc-4bc2-b645-e86e2bcc8c30"],

Cell[BoxData[
 RowBox[{
  RowBox[{"constEML", "=", 
   RowBox[{"Import", "[", "\"\<eml_tests_out/const_eml.wl\>\"", "]"}]}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.9664961532063313`*^9, 3.966496169368572*^9}, {
   3.966497920735737*^9, 3.96649792384009*^9}, 3.966498638750332*^9, 
   3.9665021874154377`*^9, {3.967162549811922*^9, 3.9671625536903152`*^9}},
