Notebook[{

Cell[CellGroupData[{
Cell["EML Symbolic Check", "Title",ExpressionUUID->"64123041-f3ae-40f3-af2a-4168b25a7797"],

Cell["\<\
This notebook encodes small constants and elementary operations in an \
EML-only reverse-Polish language and simplifies the resulting symbolic forms.\
\>", "Text",ExpressionUUID->"c0b07ec7-7ec2-4328-a3b1-039aebce10cb"],

Cell["\<\
Evaluate from top to bottom to inspect the adopted Log[0] convention, the RPN \
reduction rule, and each encoded construction.\
\>", "Text",ExpressionUUID->"fa0048b2-cf85-40dc-8d3d-b458e4a65554"],

Cell[CellGroupData[{

Cell["Conventions And RPN Rule", "Section",ExpressionUUID->"13b14ed0-99bc-4a26-9eac-6bb10ccfb833"],

Cell["\<\
Sets the working convention for Log[0], defines the EML Sheffer operator, and \
introduces the RPN reducer used throughout the notebook.\
\>", "Text",ExpressionUUID->"ce60d66b-d3bb-4268-a932-ab8b7360bfb3"],

Cell[BoxData[
 RowBox[{"Log", "[", "0", "]"}]], "Input",
 CellChangeTimes->{{3.9830996870303116`*^9, 3.9830996945635624`*^9}, 
   3.9830997445235176`*^9},
 CellLabel->"In[1]:=",ExpressionUUID->"07eb2e8f-1f11-a943-98e0-ecf81b89279c"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Unprotect", "[", "Log", "]"}], ";", 
   RowBox[{
    RowBox[{"Log", "[", "0", "]"}], "=", "Undefined"}], ";"}], " ", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
     RowBox[{
     "Comment", " ", "out", " ", "or", " ", "skip", " ", "this", " ", "line", 
      " ", "to", " ", "use", " ", "standard", " ", "convention", " ", 
      RowBox[{"Log", "[", "0", "]"}]}], "==", 
     TagBox[
      StyleBox[
       RowBox[{"DirectedInfinity", "[", 
        RowBox[{"-", "1"}], "]"}],
       ShowSpecialCharacters->False,
       ShowStringCharacters->True,
       NumberMarks->True],
      FullForm]}], ",", " ", 
    RowBox[{"i", ".", "e", ".", " ", 
     RowBox[{"-", "\[Infinity]"}]}]}], " ", "*)"}]}]], "Input",
 CellChangeTimes->{{3.9828904356677284`*^9, 3.9828904459379234`*^9}, {
   3.983099661366968*^9, 3.983099737613243*^9}, 3.9832458737378864`*^9, 
   3.9832459790801525`*^9},
 CellLabel->"In[2]:=",ExpressionUUID->"2ac252b2-31db-a14b-a39d-18bb5077cffa"],

Cell[BoxData[
 RowBox[{"Log", "[", "0", "]"}]], "Input",
 CellChangeTimes->{{3.9830997479075184`*^9, 3.98309974889196*^9}},
 CellLabel->"In[3]:=",ExpressionUUID->"98a39175-349a-9347-8735-988c2a746182"],

Cell[BoxData[
 RowBox[{
  RowBox[{"EML", "[", 
   RowBox[{"x_", ",", "y_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{"Exp", "[", "x", "]"}], "-", 
   RowBox[{"Log", "[", "y", "]"}], " ", 
   RowBox[{"(*", " ", 
    RowBox[{"EML", " ", "Sheffer", " ", "operator"}], " ", 
    "*)"}]}]}]], "Input",
 CellChangeTimes->{{3.982801105747959*^9, 3.9828011187297115`*^9}, {
  3.9828039112221565`*^9, 3.9828039192167225`*^9}, {3.9830997583812065`*^9, 
  3.9830997668197346`*^9}},
 CellLabel->"In[4]:=",ExpressionUUID->"4fc74139-3548-d048-9e61-b86bf212d27d"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"RPN", " ", "calculator"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"functions", "=", 
     RowBox[{"{", "}"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"binaryOperations", "=", 
     RowBox[{"{", "EML", "}"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"funs", "=", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"functions", "==", 
        RowBox[{"{", "}"}]}], ",", "Null", ",", 
       RowBox[{"functions", "/.", " ", 
        RowBox[{"List", "->", "Alternatives"}]}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"ops", "=", 
     RowBox[{"binaryOperations", "/.", " ", 
      RowBox[{"List", "->", "Alternatives"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"language", "=", 
     RowBox[{
      RowBox[{"Join", "[", 
       RowBox[{"functions", ",", "binaryOperations"}], "]"}], "/.", " ", 
      RowBox[{"List", "->", "Alternatives"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"rpnRule", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"a", ":", 
         RowBox[{
          RowBox[{"Except", "[", "language", "]"}], "..."}]}], ",", 
        RowBox[{"b", ":", 
         RowBox[{"Except", "[", "language", "]"}]}], ",", 
        RowBox[{"c", ":", 
         RowBox[{"Except", "[", "language", "]"}]}], ",", 
        RowBox[{"op", ":", "ops"}], ",", "d___"}], "}"}], "]"}], ":=", 
     RowBox[{"rpnRule", "[", 
      RowBox[{"{", 
       RowBox[{"a", ",", 
        RowBox[{"op", "[", 
         RowBox[{"b", ",", "c"}], "]"}], ",", "d"}], "}"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"rpnRule", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"a", ":", 
         RowBox[{
          RowBox[{"Except", "[", "language", "]"}], "..."}]}], ",", 
        RowBox[{"b", ":", 
         RowBox[{"Except", "[", 
          RowBox[{"ops", "|", "funs"}], "]"}]}], ",", 
        RowBox[{"f", ":", "funs"}], ",", "c___"}], "}"}], "]"}], ":=", 
     RowBox[{"rpnRule", "[", 
      RowBox[{"{", 
       RowBox[{"a", ",", 
        RowBox[{"f", "[", "b", "]"}], ",", "c"}], "}"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"rpnRule", "[", 
      RowBox[{"{", 
       RowBox[{"rest", ":", 
        RowBox[{"Except", "[", "language", "]"}]}], "}"}], "]"}], ":=", 
     "rest"}], ";"}]}]}]], "Input",
 CellChangeTimes->{{3.9828010668551807`*^9, 3.9828010668551807`*^9}, 
   3.982803889118353*^9, {3.982920365115309*^9, 3.9829203652425365`*^9}},
 CellLabel->"In[5]:=",ExpressionUUID->"5335cd77-50ad-344a-a006-5466ff15aa64"]
}, Open  ]],

