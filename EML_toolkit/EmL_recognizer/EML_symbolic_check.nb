          RowBox[{"ops", "|", "funs"}], "]"}]}], ",", 
        RowBox[{"f", ":", "funs"}], ",", "c___"}], "}"}], "]"}], ":=", 
     RowBox[{"rpnRule", "[", 
      RowBox[{"{", 
