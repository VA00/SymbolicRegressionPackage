Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"RPN", " ", "calculator"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"funs", "=", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"functions", "==", 
        RowBox[{"{", "}"}]}], ",", "Null", ",", 
       RowBox[{"functions", "/.", " ", 
        RowBox[{"List", "->", "Alternatives"}]}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"ops", "=", 
     RowBox[{"binaryOperations", "/.", " ", 
      RowBox[{"List", "->", "Alternatives"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"language", "=", 
     RowBox[{
      RowBox[{"Join", "[", 
       RowBox[{"functions", ",", "binaryOperations"}], "]"}], "/.", " ", 
      RowBox[{"List", "->", "Alternatives"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"rpnRule", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"a", ":", 
         RowBox[{
          RowBox[{"Except", "[", "language", "]"}], "..."}]}], ",", 
        RowBox[{"b", ":", 
         RowBox[{"Except", "[", "language", "]"}]}], ",", 
        RowBox[{"c", ":", 
         RowBox[{"Except", "[", "language", "]"}]}], ",", 
        RowBox[{"op", ":", "ops"}], ",", "d___"}], "}"}], "]"}], ":=", 
     RowBox[{"rpnRule", "[", 
      RowBox[{"{", 
       RowBox[{"a", ",", 
        RowBox[{"op", "[", 
         RowBox[{"b", ",", "c"}], "]"}], ",", "d"}], "}"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"rpnRule", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"a", ":", 
         RowBox[{
          RowBox[{"Except", "[", "language", "]"}], "..."}]}], ",", 
        RowBox[{"b", ":", 
         RowBox[{"Except", "[", 
          RowBox[{"ops", "|", "funs"}], "]"}]}], ",", 
        RowBox[{"f", ":", "funs"}], ",", "c___"}], "}"}], "]"}], ":=", 
     RowBox[{"rpnRule", "[", 
      RowBox[{"{", 
       RowBox[{"a", ",", 
        RowBox[{"f", "[", "b", "]"}], ",", "c"}], "}"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"rpnRule", "[", 
      RowBox[{"{", 
       RowBox[{"rest", ":", 
        RowBox[{"Except", "[", "language", "]"}]}], "}"}], "]"}], ":=", 
     "rest"}], ";"}]}]}]], "Input",
