        RowBox[{"b", ":", 
         RowBox[{"Except", "[", 
          RowBox[{"ops", "|", "funs"}], "]"}]}], ",", 
        RowBox[{"f", ":", "funs"}], ",", "c___"}], "}"}], "]"}], ":=", 
     RowBox[{"rpnRule", "[", 
      RowBox[{"{", 
       RowBox[{"a", ",", 
        RowBox[{"f", "[", "b", "]"}], ",", "c"}], "}"}], "]"}]}], ";"}], "\n", 
