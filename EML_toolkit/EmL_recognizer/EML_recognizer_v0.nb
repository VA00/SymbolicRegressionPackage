Notebook[{
Cell[BoxData[
 RowBox[{
  RowBox[{"ValidateCodeGeneral", "[", "digits_List", "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"counter", ",", "k", ",", "arity"}], "}"}], ",", 
    RowBox[{
     RowBox[{"counter", "=", "0"}], ";", "\[IndentingNewLine]", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"k", "=", "1"}], ",", 
       RowBox[{"k", "<=", 
        RowBox[{"Length", "[", "digits", "]"}]}], ",", 
       RowBox[{"k", "++"}], ",", 
       RowBox[{
        RowBox[{"arity", "=", 
         RowBox[{"digits", "[", 
          RowBox[{"[", "k", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"arity", "==", "0"}], ",", 
          RowBox[{
           RowBox[{"counter", "++"}], ";"}], "  ", 
          RowBox[{"(*", "Operand", "*)"}], ",", 
          RowBox[{
           RowBox[{"counter", "-=", "arity"}], ";", 
           RowBox[{"(*", 
            RowBox[{
            "Operator", " ", "consumes", " ", "`arity`", " ", "operands"}], 
            "*)"}], 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"counter", "<", "0"}], ",", 
             RowBox[{"Return", "[", "False", "]"}]}], "]"}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"counter", "++"}], ";"}]}], "  ", 
         RowBox[{"(*", 
          RowBox[{"Operator", " ", "produces", " ", "one", " ", "result"}], 
          "*)"}], "]"}], ";"}]}], "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Return", "[", 
      RowBox[{"counter", "==", "1"}], "]"}], ";"}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.9828004658912582`*^9, 3.9828004658912582`*^9}},
 CellLabel->"In[1]:=",ExpressionUUID->"fdf3b420-1125-ea46-8df4-fc3c4bf7f5e2"],

